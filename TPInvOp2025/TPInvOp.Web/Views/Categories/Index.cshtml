@model IEnumerable<CategoryListVm>
@*//Al agregar una new cat. si el teamdata es distinto
    de null muestra el mensaje que lo pudo agregar*@
@if (TempData.Count > 0)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <strong>✔ OK!</strong> @TempData["success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
    </div>
}

<div class="card shadow rounded mt-4 mb-5">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0">Category List</h4>
        <a class="btn btn-light text-primary fw-bold" asp-controller="Categories" asp-action="Create">
            <i class="bi bi-plus-circle me-1"></i> New Category
        </a>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="alert alert-warning m-3">
                <p>There are no registered categories</p>
            </div>
        }
        else
        {
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Is Active</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var category in Model)
                    {
                        <tr>
                            <td>@category.CategoryName</td>
                            @*  <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@payment.PaymentMethodID" class="btn btn-sm btn-outline-warning me-1">
                                    <i class="bi bi-pencil-square"></i> Edi
                                </a>
                                <a asp-action="Delete" asp-route-id="@payment.PaymentMethodID" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </td> *@
                            <td>
                                @if (category.IsActive)
                                {
                                    <span class="badge bg-success">Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No</span>
                                }
                            </td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-warning me-1" asp-controller="Categories" asp-action="Edit" asp-route-id="@category.CategoryId">
                                    <i class="bi bi-pencil-square"></i>
                                    Edit
                                </a>
                                <a class="btn btn-sm btn-outline-danger" asp-controller="Categories" asp-action="Delete" asp-route-id="@category.CategoryId">
                                    <i class="bi bi-trash"></i>
                                    Delete
                                </a>
                            </td>

                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>@* 

