@model LocalityEditVm


<form method="post" asp-action="Create">
    <h1>Locality Create</h1>
    <div class="mb-3">
        <p class="text-muted">
            In this space, you can create a new category.<br />
            Please be responsible and follow the guidelines.<br />
            <br />
            •He name is required.<br />
            •It must be between 3 and 50 characters.<br />
        </p>
    </div>

    <div asp-validation-summary="ModelOnly" class="invalid-feedback d-block"> </div>@*//En caso de no ser valido muestra el error@ *@

    <div class="mb-3">
        <label class="form-label" asp-for="LocalityName"></label>
        <input class="form-control" asp-for="LocalityName">
        <span class="invalid-feedback d-block" asp-validation-for="LocalityName"></span>
    </div>
    <div class="mb-3 form-check">
        <input class="form-check-input" asp-for="Delivery" type="checkbox" />
        <label class="form-check-label" asp-for="Delivery"></label>
    </div>

    <button type="submit" class="btn btn-success">Save</button>
    <a class="btn btn-primary" asp-controller="Localities" asp-action="Index">Cancel</a>
</form>

@section Scripts{
    @{
        <partial name ="_ValidationScriptsPartial" />
    }
}