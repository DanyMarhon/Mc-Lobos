@model LocalityEditVm
<form method="post">
    @Html.AntiForgeryToken();
    <input type="hidden" asp-for="LocalityId" />
    <div class="border p-3 m-4 w-75 mx-auto">
        <div class="row pb-2">
            <h2 class="text-primary">Remove Locality</h2>
            <h5 class="text-secondary">Confirm action by pressing the button below</h5>
            <hr />
        </div>
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="mb-3 row p-1">
            <label class="p-0" asp-for="LocalityName"></label>
            <input class="form-control" asp-for="LocalityName" readonly />
        </div>

        <div class="form-group form-check">
            <input class="form-check-input" asp-for="Delivery" type="checkbox" readonly />
            <label class="form-check-label" asp-for="Delivery"></label>

        </div>

        <button class="btn btn-danger" type="submit">
            <i class="bi bi-floppy2-fill"></i>
            Remove
        </button>
        <a class="btn btn-success" asp-controller="Localities" asp-action="Index">
            <i class="bi bi-backspace"></i>
            Back to List
        </a>
    </div>
</form>
@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}