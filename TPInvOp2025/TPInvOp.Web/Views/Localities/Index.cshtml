@model IEnumerable<LocalityListVm>
@*//Al agregar una new cat. si el teamdata es distinto
    de null muestra el mensaje que lo pudo agregar*@
@if (TempData.Count > 0)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <strong>OK!</strong> @TempData["success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
<div class="row">
	<div class="col-6">
		<h1>Locality List</h1>
	</div>
    <div class="col-6 text-end">
		<a class="btn btn-primary" asp-controller="Localities" asp-action="Create">Create New Locality</a>
	</div>
</div>
<table>
    <thead>
        <tr>
            <th>
					<label asp-for="@Model.First().LocalityName"> </label>
            </th>
        </tr>
    </thead>
    <tbody>
        @foreach (var locality in Model)
        {
            <tr>
                <td>
                    @locality.LocalityName
                </td>
            </tr>
        }
    </tbody>
</table>
