@using TPInvOp.Web.ViewModels.PaymentMethod
@model IEnumerable<PaymentMethodListVm>

@if (TempData["success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <strong>✔ OK!</strong> @TempData["success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
    </div>
}

<div class="card shadow rounded mt-4">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0">Lista de Métodos de Pago</h4>
        <a class="btn btn-light text-primary fw-bold" asp-controller="PaymentMethod" asp-action="Create">
            <i class="bi bi-plus-circle me-1"></i> Nuevo Método
        </a>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="alert alert-warning m-3">
                No hay métodos de pago registrados aún.
            </div>
        }
        else
        {
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Nombre</th>
                        <th>Activo</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var payment in Model)
                    {
                        <tr>
                            <td>@payment.Name</td>
                            <td>
                                @if (payment.IsActive)
                                {
                                    <span class="badge bg-success">Sí</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No</span>
                                }
                            </td>
                           @*  <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@payment.PaymentMethodID" class="btn btn-sm btn-outline-warning me-1">
                                    <i class="bi bi-pencil-square"></i> Editar
                                </a>
                                <a asp-action="Delete" asp-route-id="@payment.PaymentMethodID" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i> Eliminar
                                </a>
                            </td> *@
                            <td class="text-end">
                                <button type="button" class="btn btn-sm btn-outline-warning me-1" data-bs-toggle="modal" data-bs-target="#unavailableModal">
                                    <i class="bi bi-pencil-square"></i> Editar
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#unavailableModal">
                                    <i class="bi bi-trash"></i> Eliminar
                                </button>
                            </td>

                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
<div class="modal fade" id="unavailableModal" tabindex="-1" aria-labelledby="unavailableModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title" id="unavailableModalLabel">Atención</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body text-center">
                <i class="bi bi-exclamation-triangle display-4 text-warning mb-3"></i>
                <p class="fs-5 mb-0">Contenido no disponible en este momento.</p>
            </div>
            <div class="modal-footer justify-content-center">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>
