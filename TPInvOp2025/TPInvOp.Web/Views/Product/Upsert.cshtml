@model ProductEditVm
<form method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ProductId" />
    <div class="border p-3 m-4 w-75 mx-auto">
        <div class="row pb-2">
            <h2 class="text-primary">@(Model.ProductId == 0 ? "Add Product" : "Update Product")</h2>
            <hr />
        </div>
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="mb-3 row p-1">
            <label class="p-0" asp-for="ProductName"></label>
            <input class="form-control" asp-for="ProductName" />
            <span class="text-danger" asp-validation-for="ProductName"></span>
        </div>
        <div class="mb-3 row p-1">
            <label class="p-0" asp-for="Description"></label>
            <textarea class="form-control" asp-for="Description" style="width:100%; height:10"></textarea>
            <span class="text-danger" asp-validation-for="Description"></span>
        </div>
        <div class="mb-3 row p-1">
            <label class="p-0" asp-for="Price"></label>
            <input class="form-control" asp-for="Price" type="number" step="0.01" min="0" />
            <span class="text-danger" asp-validation-for="Price"></span>
        </div>
        <div class="mb-3 row p-1">
            <label class="p-0" asp-for="CategoryID"></label>
            <select class="form-control" asp-for="CategoryID" asp-items="@Model.Categories">
                <option selected disabled="">-- Select Category --</option>
            </select>
            <span class="text-danger" asp-validation-for="CategoryID"></span>
        </div>
        <div class="form-check mb-4">
            <input type="checkbox" asp-for="IsActive" class="form-check-input" />
            <label class="form-check-label" asp-for="IsActive">
                Is Active ?
            </label>
        </div>
        @if (Model.ProductId == 0)
        {
            <button class="btn btn-primary" type="submit">
                <i class="bi bi-floppy2-fill"></i>
                Save
            </button>
        }
        else
        {
            <button class="btn btn-warning" type="submit">
                <i class="bi bi-floppy2-fill"></i>
                Update
            </button>
        }
        <a class="btn btn-success" asp-controller="Product" asp-action="Index">
            <i class="bi bi-backspace"></i>
            Back to List
        </a>
    </div>
</form>

@section Scripts {
    <script src="https://cdn.tiny.cloud/1/ee4otp9ao47w6zc7rvtt4pdkf4mzwi5nzj603z034gzx78i0/tinymce/7/tinymce.min.js" referrerpolicy="origin"></script>

    <script src="~/js/tema.js"></script> 

    <partial name="_ValidationScriptsPartial" />
}